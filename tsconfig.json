{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "jsx": "react",
    "strict": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "App.tsx",
    "babel.config.js",
    "constants/**/*.ts",
    "utils/**/*.ts",
    "navigation/**/*.tsx",
    "screens/**/*.tsx"
  ],
  "exclude": ["node_modules", "src"]
}
